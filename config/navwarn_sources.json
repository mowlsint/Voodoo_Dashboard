{
  "version": 1,
  "name": "VOODOO NAVTEX / NAVWARN Sources",
  "description": "Official MSI/NAVTEX/NAVWARN sources for /api/navtex. Context layer, not normal noisy issue ingest.",
  "defaults": {
    "enabled": true,
    "timeout_ms": 12000,
    "max_items_per_source": 40,
    "cache_ttl_seconds": 1800,
    "labels": [
      "SRC:OFFICIAL",
      "RF:NAVWARN",
      "D:NEWS_INTEL"
    ]
  },
  "sources": [
    {
      "id": "bsh_warnings",
      "name": "BSH – Warnungen und Nachrichten",
      "country": "DE",
      "type": "html",
      "url": "https://www.bsh.de/DE/THEMEN/Schifffahrt/Nautische_Informationen/Warnungen_und_Nachrichten/warnungen_und_nachrichten_node.html",
      "parser": "generic_warning_page",
      "related_regions": [
        "REG:GER_BIGHT",
        "REG:NORTH_SEA",
        "REG:BALTIC"
      ],
      "navtex_context": [
        "NAVTEX_GERMAN_BIGHT",
        "NAVTEX_BALTIC_WEST"
      ],
      "priority": 95,
      "enabled": true
    },
    {
      "id": "elwis_seewarndienst",
